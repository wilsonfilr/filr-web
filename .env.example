# Filr web app — Supabase connection (same project as the mobile app).
# Copy to .env.local and fill in. These are public (anon) values, safe to ship in a browser bundle.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Sign in with Apple (web) — Apple Developer → Identifiers → Services ID (not the iOS App ID).
# Example: com.wilsonfilr.filr.web
VITE_APPLE_SERVICES_ID=

# Production URL for Apple/Google OAuth redirects (optional locally; set on Vercel).
# Example: https://web.myfilr.app
# VITE_SITE_URL=

# Optional: EAS Hosting URL for File it AI in production builds (web.myfilr.app).
# Local dev uses the Vite proxy automatically — do not point this at EAS in .env.local.
# Example: https://papr-cursor.expo.app
# VITE_API_BASE_URL=
